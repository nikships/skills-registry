# skills-registry configuration — every variable is optional.
# Copy to `.env` and tweak, or set the variables directly in your MCP client config.

# Override the on-disk registry config for one process.
# Format: "owner/repo" or "owner/repo@branch".
# SKILLS_REGISTRY=anand-92/my-skill-registry

# Directory the `skills-registry init` bootstrap installs the Go binary into.
# SKILLS_BIN_DIR=~/.local/bin

# GitHub repo `skills-registry init` downloads the Go CLI release from.
# SKILLS_CLI_REPO=anand-92/skills-registry

# Per-file size limit (bytes) that `publish_skill` enforces.
# SKILLS_MAX_FILE_BYTES=2097152

# Log verbosity for the MCP server (CRITICAL | ERROR | WARNING | INFO | DEBUG).
# SKILLS_LOG_LEVEL=INFO

# Standard XDG paths the server respects. Override if you keep config/cache
# somewhere unusual.
# XDG_CONFIG_HOME=~/.config
# XDG_CACHE_HOME=~/.cache

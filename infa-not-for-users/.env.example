# Hosted MCP server — required env vars at boot.
# Copy to `.env` for local Docker runs, or set these directly in Railway's
# service config. `load_settings()` (in skills_mcp/remote_server.py) fails
# fast if any required value is missing or blank.

# ─── FastMCP OAuth (GitHub identity provider) ──────────────────────────
# Public base URL of the deployed server (no trailing /mcp; the FastMCP
# Streamable-HTTP route is appended at runtime).
FASTMCP_SERVER_AUTH_GITHUB_BASE_URL=https://mcp.skills-registry.dev
# Credentials for the GitHub OAuth App that lets MCP clients log in.
FASTMCP_SERVER_AUTH_GITHUB_CLIENT_ID=
FASTMCP_SERVER_AUTH_GITHUB_CLIENT_SECRET=

# ─── GitHub App (resource access) ──────────────────────────────────────
# These come from the "Skills Registry" GitHub App users install on their
# registry repo. The App's installation token is what grants the server
# read access to the user's repo on every list_skills / get_skill call.
GITHUB_APP_ID=
GITHUB_APP_SLUG=skills-registry
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_WEBHOOK_SECRET=

# ─── Secrets ───────────────────────────────────────────────────────────
# HS256 key for FastMCP-issued bearer tokens.
JWT_SIGNING_KEY=
# Fernet key used to encrypt persistent KV entries (OAuth state, link
# table) on the Railway volume. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
STORAGE_ENCRYPTION_KEY=

# ─── Storage / runtime ────────────────────────────────────────────────
# Directory where OAuth + link-table state is persisted. On Railway, this
# is mounted from the volume — see railway.json's mount config.
FASTMCP_STORAGE_DIR=/data/oauth

# Optional. Defaults shown.
# HOST=0.0.0.0
# PORT=8000
# SKILLS_LOG_LEVEL=INFO
